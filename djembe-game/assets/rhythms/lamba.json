  "culturalInfo": {
    "ko": {
      "summary": "그리오(Griot, 음악인 가문)를 위한 신성한 리듬. 그들에게 경의를 표한다.",
      "history": "서아프리카의 그리오는 대대로 가문의 역사와 전통을 노래로 전승하는 음유시인이다. Lamba는 그들을 위한 헌정 리듬으로, 일반인은 함부로 연주하지 못한다.",
      "occasion": "그리오 가문 행사, 코라(Kora) 연주 동반, 결혼식 입장",
      "dance": "그리오가 노래하는 동안 다른 이들이 절제된 동작으로 화답하는 형태",
      "famousArtists": ["Toumani Diabaté (Kora)", "Mamady Keïta", "Ballaké Sissoko"]
    },
    "en": {
      "summary": "A sacred rhythm for the Griot (musician caste), expressing reverence for them.",
      "history": "In West Africa, the Griots are bardic poets who transmit family history and tradition through song across generations. Lamba is a dedicatory rhythm for them — not casually played by laypeople.",
      "occasion": "Griot family events, accompaniment to Kora playing, wedding processions",
      "dance": "Others respond with restrained movements while a Griot sings",
      "famousArtists": ["Toumani Diabaté (Kora)", "Mamady Keïta", "Ballaké Sissoko"]
    }
  },
